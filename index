<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Random Matching</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #ffffff; 
      --surface: #f9f9fa; 
      --surface2: #f0f0f4; 
      --border: rgba(0,0,0,0.08);
      --border2: rgba(0,0,0,0.18);
      --text: #1a1a1f;
      --muted: #6e6e77;
      --accent: #000000; 
      --accent-dim: rgba(0,0,0,0.06);
      --accent-dim2: rgba(0,0,0,0.12);
      --col-a: #0284c7; 
      --col-b: #ea580c; 
      --col-a-dim: rgba(2,132,199,0.08);
      --col-b-dim: rgba(234,88,12,0.08);
      --radius: 10px;
      --radius-lg: 16px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Syne', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Noise overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.02'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
    }

    .glow {
      position: fixed;
      width: 500px; height: 500px;
      border-radius: 50%;
      filter: blur(120px);
      pointer-events: none;
      z-index: 0;
    }
    .glow-1 { top: -150px; left: -100px; background: rgba(2,132,199,0.05); }
    .glow-2 { bottom: -150px; right: -100px; background: rgba(234,88,12,0.05); }

    .container {
      max-width: 820px;
      margin: 0 auto;
      padding: 60px 24px 80px;
      position: relative;
      z-index: 1;
    }

    header {
      margin-bottom: 52px;
    }

    .tag {
      display: inline-block;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid rgba(0,0,0,0.25);
      padding: 4px 12px;
      border-radius: 999px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 20px;
    }

    h1 {
      font-size: clamp(36px, 6vw, 58px);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 12px;
    }

    h1 span { color: var(--accent); }

    .subtitle {
      font-size: 15px;
      color: var(--muted);
      font-weight: 400;
      line-height: 1.6;
    }

    /* Input section */
    .input-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 24px;
    }

    @media (max-width: 560px) {
      .input-grid { grid-template-columns: 1fr; }
    }

    .col-panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 20px;
      transition: border-color 0.2s;
    }

    .col-panel:hover { border-color: var(--border2); }

    .col-label {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .col-label.a { color: var(--col-a); }
    .col-label.b { color: var(--col-b); }

    .col-label .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .col-label.a .dot { background: var(--col-a); }
    .col-label.b .dot { background: var(--col-b); }

    textarea {
      width: 100%;
      min-height: 140px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      line-height: 1.8;
      padding: 12px 14px;
      resize: vertical;
      outline: none;
      transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    }

    textarea:focus {
      border-color: var(--border2);
      background: #ffffff;
      box-shadow: 0 0 0 3px rgba(0,0,0,0.03);
    }

    textarea::placeholder { color: var(--muted); opacity: 0.5; }

    .hint {
      font-size: 11px;
      color: var(--muted);
      margin-top: 8px;
      font-family: 'DM Mono', monospace;
      opacity: 0.6;
    }

    .count-badge {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 999px;
      margin-left: auto;
    }

    .col-label.a .count-badge { background: var(--col-a-dim); color: var(--col-a); }
    .col-label.b .count-badge { background: var(--col-b-dim); color: var(--col-b); }

    /* Actions */
    .actions {
      display: flex;
      gap: 12px;
      margin-bottom: 48px;
      flex-wrap: wrap;
    }

    .btn-primary {
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: #ffffff;
      background: var(--accent);
      border: none;
      padding: 13px 28px;
      border-radius: var(--radius);
      cursor: pointer;
      transition: transform 0.15s, opacity 0.15s, box-shadow 0.15s;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn-primary:hover { 
      transform: translateY(-1px); 
      box-shadow: 0 6px 20px rgba(0,0,0,0.15); 
    }
    
    .btn-primary:active { transform: scale(0.97); }
    .btn-primary:disabled { opacity: 0.35; cursor: not-allowed; transform: none; box-shadow: none; }

    .btn-secondary {
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: var(--muted);
      background: transparent;
      border: 1px solid var(--border2);
      padding: 12px 20px;
      border-radius: var(--radius);
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }

    .btn-secondary:hover { background: var(--surface); color: var(--text); }

    /* Results */
    #results-section {
      display: none;
      animation: fadeUp 0.4s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .results-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .results-title {
      font-size: 13px;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .results-title strong {
      color: var(--accent);
      font-weight: 500;
    }

    .pairs-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .pair-row {
      display: grid;
      grid-template-columns: 1fr 48px 1fr;
      align-items: center;
      gap: 0;
      opacity: 0;
      transform: translateX(-12px);
      animation: slideIn 0.35s ease forwards;
    }

    @keyframes slideIn {
      to { opacity: 1; transform: translateX(0); }
    }

    .pair-cell {
      padding: 14px 18px;
      border-radius: var(--radius);
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.01em;
      position: relative;
    }

    .pair-cell.a {
      background: var(--col-a-dim);
      border: 1px solid rgba(2,132,199,0.2);
      color: var(--col-a);
      text-align: right;
      border-radius: var(--radius) 0 0 var(--radius);
    }

    .pair-cell.b {
      background: var(--col-b-dim);
      border: 1px solid rgba(234,88,12,0.2);
      color: var(--col-b);
      text-align: left;
      border-radius: 0 var(--radius) var(--radius) 0;
    }

    .pair-connector {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      position: relative;
    }

    .pair-connector::before {
      content: '';
      position: absolute;
      left: 0; right: 0;
      top: 50%;
      height: 1px;
      background: linear-gradient(90deg, rgba(2,132,199,0.4), rgba(234,88,12,0.4));
    }

    .pair-connector .arrow {
      width: 28px; height: 28px;
      background: var(--surface2);
      border: 1px solid var(--border2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      color: var(--muted);
      position: relative;
      z-index: 1;
      flex-shrink: 0;
    }

    .index-num {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      opacity: 0.5;
      width: 24px;
      text-align: right;
      flex-shrink: 0;
      align-self: center;
    }

    /* Error */
    .error-msg {
      display: none;
      background: rgba(240,80,80,0.1);
      border: 1px solid rgba(240,80,80,0.25);
      color: #e11d48;
      font-size: 13px;
      font-family: 'DM Mono', monospace;
      padding: 12px 16px;
      border-radius: var(--radius);
      margin-bottom: 16px;
    }

    /* History */
    #history-section {
      margin-top: 56px;
      display: none;
    }

    .history-label {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      margin-bottom: 16px;
      opacity: 0.6;
    }

    .history-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .history-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 18px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }

    .history-item:hover { border-color: var(--border2); background: var(--surface2); }

    .history-meta {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--muted);
    }

    .history-preview {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .copy-btn {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid rgba(0,0,0,0.1);
      padding: 6px 14px;
      border-radius: 999px;
      cursor: pointer;
      transition: background 0.15s;
      white-space: nowrap;
    }
    .copy-btn:hover { background: var(--accent-dim2); }

    .divider {
      height: 1px;
      background: var(--border);
      margin: 48px 0;
    }

    footer {
      text-align: center;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      opacity: 0.4;
      margin-top: 80px;
    }
  </style>
</head>
<body>
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>

  <div class="container">
    <header>
      <div class="tag">Random Matching</div>
      <h1>Nối đôi<br/><span>ngẫu nhiên</span></h1>
      <p class="subtitle">Nhập hai danh sách, nhấn random — kết quả ghép cặp 1-1 ngẫu nhiên ngay lập tức.</p>
    </header>

    <div class="input-grid">
      <div class="col-panel">
        <div class="col-label a">
          <span class="dot"></span>
          Danh sách A
          <span class="count-badge" id="count-a">0</span>
        </div>
        <textarea id="list-a" placeholder="Nhập mỗi mục trên một dòng&#10;Ví dụ:&#10;Đỏ&#10;Xanh&#10;Vàng&#10;Cam"></textarea>
        <p class="hint">// mỗi dòng = 1 mục</p>
      </div>

      <div class="col-panel">
        <div class="col-label b">
          <span class="dot"></span>
          Danh sách B
          <span class="count-badge" id="count-b">0</span>
        </div>
        <textarea id="list-b" placeholder="Nhập mỗi mục trên một dòng&#10;Ví dụ:&#10;Người A&#10;Người B&#10;Người C&#10;Người D"></textarea>
        <p class="hint">// mỗi dòng = 1 mục</p>
      </div>
    </div>

    <div class="error-msg" id="error-msg"></div>

    <div class="actions">
      <button class="btn-primary" id="btn-random" onclick="doRandom()">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 2l4 4-4 4M2 6h12M6 14l-4-4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Random ngay
      </button>
      <button class="btn-secondary" onclick="loadExample()">Thử ví dụ mẫu</button>
      <button class="btn-secondary" onclick="clearAll()">Xóa tất cả</button>
    </div>

    <div id="results-section">
      <div class="results-header">
        <div class="results-title">Kết quả — <strong id="pair-count">0</strong> cặp</div>
        <div style="display:flex;gap:8px;">
          <button class="copy-btn" onclick="copyResults()">Sao chép kết quả</button>
          <button class="copy-btn" onclick="doRandom()" style="color:var(--col-a);background:var(--col-a-dim);border-color:rgba(2,132,199,0.2);">Xáo lại</button>
        </div>
      </div>
      <div class="pairs-list" id="pairs-list"></div>
    </div>

    <div id="history-section">
      <div class="divider"></div>
      <div class="history-label">// lịch sử random</div>
      <div class="history-list" id="history-list"></div>
    </div>

    <footer>random-matching · open source · github</footer>
  </div>

  <script>
    let history = JSON.parse(localStorage.getItem('rmx-history') || '[]');

    function getItems(id) {
      return document.getElementById(id).value
        .split('\n')
        .map(s => s.trim())
        .filter(Boolean);
    }

    function updateCounts() {
      document.getElementById('count-a').textContent = getItems('list-a').length;
      document.getElementById('count-b').textContent = getItems('list-b').length;
    }

    document.getElementById('list-a').addEventListener('input', updateCounts);
    document.getElementById('list-b').addEventListener('input', updateCounts);

    function shuffle(arr) {
      const a = [...arr];
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function showError(msg) {
      const el = document.getElementById('error-msg');
      el.textContent = msg;
      el.style.display = 'block';
    }

    function hideError() {
      document.getElementById('error-msg').style.display = 'none';
    }

    function doRandom() {
      hideError();
      const a = getItems('list-a');
      const b = getItems('list-b');

      if (!a.length || !b.length) {
        showError('// Cả hai danh sách đều phải có ít nhất 1 mục.');
        return;
      }

      // Pair: use min length, shuffle both
      const len = Math.min(a.length, b.length);
      if (a.length !== b.length) {
        showError(`// Hai danh sách có số lượng khác nhau (${a.length} vs ${b.length}). Chỉ ghép ${len} cặp đầu tiên.`);
      }

      const shuffledA = shuffle(a).slice(0, len);
      const shuffledB = shuffle(b).slice(0, len);
      const pairs = shuffledA.map((item, i) => [item, shuffledB[i]]);

      renderPairs(pairs);
      saveHistory(pairs);
    }

    function renderPairs(pairs) {
      const section = document.getElementById('results-section');
      const list = document.getElementById('pairs-list');
      document.getElementById('pair-count').textContent = pairs.length;

      list.innerHTML = '';
      pairs.forEach(([a, b], i) => {
        const row = document.createElement('div');
        row.className = 'pair-row';
        row.style.animationDelay = `${i * 50}ms`;
        row.innerHTML = `
          <div class="pair-cell a">${escHtml(a)}</div>
          <div class="pair-connector"><div class="arrow">↔</div></div>
          <div class="pair-cell b">${escHtml(b)}</div>
        `;
        list.appendChild(row);
      });

      section.style.display = 'block';
    }

    function escHtml(s) {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function copyResults() {
      const list = document.getElementById('pairs-list');
      const rows = list.querySelectorAll('.pair-row');
      const text = Array.from(rows).map(r => {
        const cells = r.querySelectorAll('.pair-cell');
        return `${cells[0].textContent.trim()} ↔ ${cells[1].textContent.trim()}`;
      }).join('\n');
      navigator.clipboard.writeText(text).then(() => {
        const btn = event.target;
        const orig = btn.textContent;
        btn.textContent = 'Đã sao chép!';
        setTimeout(() => btn.textContent = orig, 1500);
      });
    }

    function saveHistory(pairs) {
      const entry = {
        id: Date.now(),
        time: new Date().toLocaleString('vi-VN'),
        pairs,
        preview: pairs.slice(0,2).map(([a,b])=>`${a}↔${b}`).join(', ') + (pairs.length > 2 ? '...' : '')
      };
      history.unshift(entry);
      if (history.length > 10) history = history.slice(0, 10);
      localStorage.setItem('rmx-history', JSON.stringify(history));
      renderHistory();
    }

    function renderHistory() {
      const section = document.getElementById('history-section');
      const list = document.getElementById('history-list');
      if (!history.length) { section.style.display = 'none'; return; }
      section.style.display = 'block';
      list.innerHTML = '';
      history.forEach(entry => {
        const item = document.createElement('div');
        item.className = 'history-item';
        item.innerHTML = `
          <div class="history-meta">${entry.time}</div>
          <div class="history-preview">${escHtml(entry.preview)}</div>
          <span style="font-size:12px;color:var(--muted);font-family:'DM Mono',monospace;">${entry.pairs.length} cặp</span>
        `;
        item.onclick = () => renderPairs(entry.pairs);
        list.appendChild(item);
      });
    }

    function loadExample() {
      document.getElementById('list-a').value = 'Đỏ\nXanh\nVàng\nCam\nTím';
      document.getElementById('list-b').value = 'Người A\nNgười B\nNgười C\nNgười D\nNgười E';
      updateCounts();
      doRandom();
    }

    function clearAll() {
      document.getElementById('list-a').value = '';
      document.getElementById('list-b').value = '';
      document.getElementById('results-section').style.display = 'none';
      hideError();
      updateCounts();
    }

    renderHistory();
  </script>
</body>
</html>
